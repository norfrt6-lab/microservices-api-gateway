# Gateway
PORT=3000
NODE_ENV=development
JWT_SECRET=your-secret-key-change-in-production
JWT_EXPIRES_IN=24h
GATEWAY_SECRET=internal-gateway-key-change-in-production
API_VERSION=v1

# Redis
REDIS_URL=redis://redis:6379

# NATS
NATS_URL=nats://nats:4222

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_AUTHENTICATED_MAX=500

# Service URLs (HTTP proxy)
USER_SERVICE_URL=http://user-service:3001
PRODUCT_SERVICE_URL=http://product-service:3002
ORDER_SERVICE_URL=http://order-service:3003

# User Service DB
USER_DB_URL=postgresql://postgres:postgres@postgres:5432/users_db

# Product Service DB
PRODUCT_DB_URL=postgresql://postgres:postgres@postgres:5432/products_db

# Order Service DB
ORDER_DB_URL=postgresql://postgres:postgres@postgres:5432/orders_db

# Observability
OTEL_EXPORTER_OTLP_ENDPOINT=http://jaeger:4318
OTEL_SERVICE_NAME=gateway
PROMETHEUS_PORT=9090

# Idempotency
IDEMPOTENCY_TTL_SECONDS=86400
