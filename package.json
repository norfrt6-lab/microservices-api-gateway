{
  "name": "microservices-api-gateway",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Microservices API Gateway with service discovery, distributed tracing, and production-grade patterns",
  "workspaces": [
    "gateway",
    "services/user-service",
    "services/product-service",
    "services/order-service",
    "shared"
  ],
  "scripts": {
    "dev:gateway": "npm run dev --workspace=gateway",
    "dev:user": "npm run dev --workspace=services/user-service",
    "dev:product": "npm run dev --workspace=services/product-service",
    "dev:order": "npm run dev --workspace=services/order-service",
    "db:generate": "prisma generate --schema services/user-service/prisma/schema.prisma && prisma generate --schema services/product-service/prisma/schema.prisma && prisma generate --schema services/order-service/prisma/schema.prisma",
    "build": "npm run db:generate && tsc -b tsconfig.build.json",
    "lint": "npm run lint --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "test:integration": "node scripts/test-integration.cjs",
    "test:contract": "node scripts/contract-test.cjs",
    "seed": "tsx scripts/seed.ts"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "eslint": "^9.0.0",
    "typescript-eslint": "^8.0.0"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0"
  }
}
